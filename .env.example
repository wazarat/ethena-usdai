# Copy this file to ".env" and fill in your values. NEVER commit ".env".
#
# Your ROTATED Dune API key. The previously exposed key must be rotated first.
# Get one at: https://dune.com/settings/api
DUNE_API_KEY=

# Your Dune namespace (used only to build the final dashboard URL string).
DUNE_NAMESPACE=wazarat

# Optional: your destination dashboard slug, for the exact CanHav hand-off URL
# (https://dune.com/<namespace>/<slug>). Leave blank to emit a placeholder.
DUNE_DASHBOARD_SLUG=

# --- Optional: pre-fill query IDs to skip the interactive prompts ---
# Open the chart on the public dashboard -> the URL shows dune.com/queries/<ID>.
#
# Ethena sUSDe / USDe supply query (e.g. from dune.com/hildobby/ethena)
ETHENA_SUPPLY_QUERY_ID=
# USD.AI sUSDai supply query (e.g. from entropy_advisors' USD.AI dashboard)
USDAI_SUPPLY_QUERY_ID=
# Optional SECONDARY row: total USDe + total USDai supply (added only if BOTH set).
ETHENA_SECONDARY_QUERY_ID=
USDAI_SECONDARY_QUERY_ID=
# Optional: a saved query that SELECTs from dune.wazarat.canhav_agent_verdicts.
# Leave blank if you don't have one saved yet (Step 3 will warn instead of fail).
VERDICTS_QUERY_ID=
